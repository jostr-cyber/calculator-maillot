{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfile": "Dockerfile"
  },
  "deploy": {
    "restartPolicyMaxRetries": 10,
    "restartPolicyCondition": "on-failure",
    "numReplicas": 1,
    "startCommand": "node server.js",
    "healthchecks": {
      "readiness": {
        "command": ["node", "-e", "require('http').get('http://localhost:8000/health', (r) => {if (r.statusCode !== 200) throw new Error(r.statusCode)})"],
        "initialDelaySeconds": 10,
        "periodSeconds": 30
      }
    }
  }
}
